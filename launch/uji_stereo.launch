<launch>

    <!-- Robots parameters -->
    <arg name = "robot_name"         default = "girona500"/>

    <!-- Camera parameters -->
    <arg name = "camera_name"        default = "stereo_ch3"/>
    <arg name = "resolution"         default = "full"/>
    <arg name = "slave_camera_name"  default = "right"/>
    <arg name = "master_camera_name" default = "left"/>

    <!-- Image flags -->
    <arg name = "enable_decimate_x1" default = "false"/>
    <arg name = "enable_decimate_x2" default = "false"/>
    <arg name = "enable_decimate_x4" default = "true"/>
    <arg name = "enable_decimate_x8" default = "false"/>

    <!-- CPU/MEM monitor flag -->
    <arg name = "enable_cpu_monitor" default = "true"/>

    <!-- Clock extension -->
    <arg name = "enable_extra_clock" default = "true"/>

    <!-- Bagfiles parameters -->
    <param name = "/use_sim_time"    value = "true"/>

    <!-- UJI -->
    <!-- 2024_07_02/experiment_0_proc -->
    <arg name = "bagfile" default = "/home/bomiquel/datasets/bagfiles/uji/2024_07_02/experiment_0_proc/2024-07-02-16-33-14.bag"/>
    <!-- 2024_07_03/experiment_0_square_1_proc -->
    <!-- <arg name = "bagfile" default = "/home/bomiquel/datasets/bagfiles/uji/2024_07_03/experiment_0_square_1_proc/2024-07-03-11-37-31.bag"/> -->
    <!-- 2024_07_04/experiment_0_square_2_proc -->
    <!-- <arg name = "bagfile" default = "/home/bomiquel/datasets/bagfiles/uji/2024_07_04/experiment_0_square_2_proc/2024-07-04-13-08-50.bag"/> -->
    <!-- 2024_07_04/experiment_0_square_3_proc -->
    <!-- <arg name = "bagfile" default = "/home/bomiquel/datasets/bagfiles/uji/2024_07_04/experiment_0_square_3_proc/2024-07-04-13-22-00.bag"/> -->

    <!-- Static TF's -->
    <node pkg = "tf" type = "static_transform_publisher" name = "girona500_base_link_to_stereo_down" args = "0.57 -0.062 0.505 0.0 0.0 0.0 /girona500/base_link /girona500/stereo_down 30"/>
    <node pkg = "tf" type = "static_transform_publisher" name = "girona500_stereo_down_to_left_optical" args = "0.0 0.0 0.0 1.57 0.0 0.0 /girona500/stereo_down /girona500/stereo_down/left_optical 30"/>

    <group ns = "$(arg robot_name)">

        <!-- Initial pose and orientation parameters -->  
        <!-- UJI 2024_07_02/experiment_0_proc -->
        <arg name = "t_x" default = "7.256682862"/> 
        <arg name = "t_y" default = "0.605927856"/> 
        <arg name = "t_z" default = "-1.758014793"/> 
        <arg name = "q_x" default = "-0.002890934"/>
        <arg name = "q_y" default = "0.030017629"/>
        <arg name = "q_z" default = "0.998787796"/>
        <arg name = "q_w" default = "0.038904031"/>
        <!-- UJI 2024_07_03/experiment_0_square_1_proc -->
        <!-- <arg name = "t_x" default = "-0.098869452"/> 
        <arg name = "t_y" default = "0.192996936"/>
        <arg name = "t_z" default = "-1.778576607"/> 
        <arg name = "q_x" default = "-0.022258513"/>
        <arg name = "q_y" default = "0.021376555"/>
        <arg name = "q_z" default = "-0.052030298"/>
        <arg name = "q_w" default = "0.998168548"/> -->
        <!-- UJI 2024_07_04/experiment_0_square_2_proc -->
        <!-- <arg name = "t_x" default = "-0.037046177"/> 
        <arg name = "t_y" default = "0.269914678"/> 
        <arg name = "t_z" default = "-1.800492732"/> 
        <arg name = "q_x" default = "-0.029828077"/>
        <arg name = "q_y" default = "0.000048010"/>
        <arg name = "q_z" default = "-0.027061236"/>
        <arg name = "q_w" default = "0.999188657"/> -->
        <!-- UJI 2024_07_04/experiment_0_square_3_proc -->
        <!-- <arg name = "t_x" default = "1.000167367"/> 
        <arg name = "t_y" default = "3.366724544"/> 
        <arg name = "t_z" default = "-1.801609401"/> 
        <arg name = "q_x" default = "0.032461234"/>
        <arg name = "q_y" default = "-0.013343311"/>
        <arg name = "q_z" default = "-0.264775157"/>
        <arg name = "q_w" default = "0.963671283"/> -->

        <!-- Sends initial pose -->
        <node pkg = "orb_slam3_ros" type = "initial_pose_server_node" name = "initial_pose_server_node" output = "screen">
            <param name = "tx"          value = "$(arg t_x)"/>
            <param name = "ty"          value = "$(arg t_y)"/>
            <param name = "tz"          value = "$(arg t_z)"/>
            <param name = "qx"          value = "$(arg q_x)"/>
            <param name = "qy"          value = "$(arg q_y)"/>
            <param name = "qz"          value = "$(arg q_z)"/>
            <param name = "qw"          value = "$(arg q_w)"/>
            <param name = "world_frame" value = "world_ned"/>
            <param name = "robot_frame" value = "base_link"/>
            <remap from = "get_pose"    to    = "orb_slam3_ros/get_first_pose"/>
        </node>

        <!-- Processes stereo images -->
        <include file = "$(find orb_slam3_ros)/launch/stereo_processing/stereo_pipeline.launch">
            <arg name = "stereo"             value = "$(arg camera_name)"/>
            <arg name = "resolution"         value = "$(arg resolution)"/>
            <arg name = "slave_camera_name"  value = "$(arg slave_camera_name)"/>
            <arg name = "master_camera_name" value = "$(arg master_camera_name)"/>
            <arg name = "enable_decimate_x1" value = "$(arg enable_decimate_x1)"/>
            <arg name = "enable_decimate_x2" value = "$(arg enable_decimate_x2)"/>
            <arg name = "enable_decimate_x4" value = "$(arg enable_decimate_x4)"/>
            <arg name = "enable_decimate_x8" value = "$(arg enable_decimate_x8)"/>
        </include>

        <!-- ORB-SLAM3 -->
        <rosparam command = "load" file = "$(find orb_slam3_ros)/config/Stereo/offline_params.yaml"/>
        <node name = "orb_slam3_ros" pkg = "orb_slam3_ros" type = "ros_stereo" output = "screen" if = "$(eval enable_decimate_x1 == true)">
            <remap from = "/camera/left/image_raw"     to = "$(arg camera_name)/$(arg master_camera_name)/image_rect_color"/>
            <remap from = "/camera/right/image_raw"    to = "$(arg camera_name)/$(arg slave_camera_name)/image_rect_color"/>
            <remap from = "get_first_pose"             to = "orb_slam3_ros/get_first_pose"/>
            <param name = "voc_file"                   type = "string"   value = "$(find orb_slam3_ros)/orb_slam3/Vocabulary/ORBvoc.txt.bin"/>
            <param name = "settings_file"              type = "string"   value = "$(find orb_slam3_ros)/config/Stereo/uji_x1.yaml"/>
            <param name = "world_frame_id"             type = "string"   value = "world_ned" />
            <param name = "base_link_frame_id"         type = "string"   value = "$(arg robot_name)/base_link" />
            <param name = "cam_frame_id"               type = "string"   value = "$(arg robot_name)/stereo_down/left_optical" />
            <param name = "enable_pangolin"            type = "bool"     value = "true" />
        </node>
        <node name = "orb_slam3_ros" pkg = "orb_slam3_ros" type = "ros_stereo" output = "screen" if = "$(eval enable_decimate_x2 == true)">
            <remap from = "/camera/left/image_raw"     to = "$(arg camera_name)/scaled_x2/$(arg master_camera_name)/image_rect_color"/>
            <remap from = "/camera/right/image_raw"    to = "$(arg camera_name)/scaled_x2/$(arg slave_camera_name)/image_rect_color"/>
            <remap from = "get_first_pose"             to = "orb_slam3_ros/get_first_pose"/>
            <param name = "voc_file"                   type = "string"   value = "$(find orb_slam3_ros)/orb_slam3/Vocabulary/ORBvoc.txt.bin"/>
            <param name = "settings_file"              type = "string"   value = "$(find orb_slam3_ros)/config/Stereo/uji_x2.yaml"/>
            <param name = "world_frame_id"             type = "string"   value = "world_ned" />
            <param name = "base_link_frame_id"         type = "string"   value = "$(arg robot_name)/base_link" />
            <param name = "cam_frame_id"               type = "string"   value = "$(arg robot_name)/stereo_down/left_optical" />
            <param name = "enable_pangolin"            type = "bool"     value = "true" />
        </node>
        <node name = "orb_slam3_ros" pkg = "orb_slam3_ros" type = "ros_stereo" output = "screen" if = "$(eval enable_decimate_x4 == true)">
            <remap from = "/camera/left/image_raw"     to = "$(arg camera_name)/scaled_x4/$(arg master_camera_name)/image_rect_color"/>
            <remap from = "/camera/right/image_raw"    to = "$(arg camera_name)/scaled_x4/$(arg slave_camera_name)/image_rect_color"/>
            <remap from = "get_first_pose"             to = "orb_slam3_ros/get_first_pose"/>
            <param name = "voc_file"                   type = "string"   value = "$(find orb_slam3_ros)/orb_slam3/Vocabulary/ORBvoc.txt.bin"/>
            <param name = "settings_file"              type = "string"   value = "$(find orb_slam3_ros)/config/Stereo/uji_x4.yaml"/>
            <param name = "world_frame_id"             type = "string"   value = "world_ned" />
            <param name = "base_link_frame_id"         type = "string"   value = "$(arg robot_name)/base_link" />
            <param name = "cam_frame_id"               type = "string"   value = "$(arg robot_name)/stereo_down/left_optical" />
            <param name = "enable_pangolin"            type = "bool"     value = "true" />
        </node>

    </group>

    <!-- Extend clok -->
    <node pkg = "orb_slam3_ros" type = "clock_extender" name = "clock_extender" required = "true" output = "screen" if = "$(eval enable_extra_clock == true)">
        <param name = "extra_time"       value = "5"/>
        <param name = "gap_threshold"    value = "15"/>
        <param name = "watch_interval"   value = "5"/>
    </node>

    <!-- CPU/RAM memory monitor -->
    <node pkg = "cpu_monitor" name = "cpu_monitor" type = "monitor.py" output = "screen" if = "$(eval enable_cpu_monitor == true)"/>

    <!-- Play bagfile -->
    <node pkg = "orb_slam3_ros" 
          type = "delayed_rosbag_play.sh" 
          name = "rosbag" 
          args = "--delay 10 --rosbag-args '-r 1 --clock $(arg bagfile) --topics /$(arg robot_name)/$(arg camera_name)/$(arg master_camera_name)/camera_info 
                                                                                 /$(arg robot_name)/$(arg camera_name)/$(arg master_camera_name)/image_raw 
                                                                                 /$(arg robot_name)/$(arg camera_name)/$(arg slave_camera_name)/camera_info 
                                                                                 /$(arg robot_name)/$(arg camera_name)/$(arg slave_camera_name)/image_raw
                                                                                 /$(arg robot_name)/navigator/odometry'"
          if = "$(eval enable_extra_clock == true)"/>

    <node pkg = "orb_slam3_ros" 
          type = "delayed_rosbag_play.sh" 
          name = "rosbag" 
          args = "--delay 10 --rosbag-args '-r 1 --clock $(arg bagfile) --topics /$(arg robot_name)/$(arg camera_name)/$(arg master_camera_name)/camera_info 
                                                                                 /$(arg robot_name)/$(arg camera_name)/$(arg master_camera_name)/image_raw 
                                                                                 /$(arg robot_name)/$(arg camera_name)/$(arg slave_camera_name)/camera_info 
                                                                                 /$(arg robot_name)/$(arg camera_name)/$(arg slave_camera_name)/image_raw
                                                                                 /$(arg robot_name)/navigator/odometry'"
          required = "true"
          if = "$(eval enable_extra_clock == false)"/>

</launch>